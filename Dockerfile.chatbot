# Car Rental Chatbot for HuggingFace Spaces
# Port: 7860

FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# Copy and install Python dependencies
COPY requirements.chatbot.txt /app/
RUN pip install --no-cache-dir -r requirements.chatbot.txt

# Copy application
COPY app.py /app/

# Set environment (these will be overridden by HuggingFace secrets)

ENV PYTHONUNBUFFERED=1
ENV HOST=0.0.0.0
ENV PORT=7860
ENV MODEL_NAME=gpt-3.5-turbo
ENV TEMPERATURE=0.7
ENV MAX_TOKENS=500

EXPOSE 7860

CMD ["python", "app.py"]